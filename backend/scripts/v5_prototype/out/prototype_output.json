    {
      "idx": 2,
      "start": 31.28,
      "end": 32.64,
      "source_text": "貓, 超喜歡貓",
      "by_lang": {
        "zh": {
          "text": "[HALLUC] 貓，超喜歡貓",
          "stage": "refined"
        },
        "en": {
          "text": "Cats, I love cats so much.",
          "stage": "translated"
        }
      }
    },
    {
      "idx": 3,
      "start": 32.72,
      "end": 34.52,
      "source_text": "我很喜歡看, 連新年都看",
      "by_lang": {
        "zh": {
          "text": "我好鍾意睇，連新年都睇",
          "stage": "refined"
