# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# Virtual environment
backend/venv/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Whisper model cache
*.pt

# Uploaded media & transcription data
backend/data/

# Temp files
*.tmp
*.log

# Claude Code
.claude/

# Skill tool state
.superpowers/

# Playwright / pytest output
test-results/

# Frontend npm artifacts (R5 Phase 1 added Playwright deps via npm)
frontend/node_modules/
frontend/playwright-report/
frontend/.playwright/
frontend.old/node_modules/
frontend.old/playwright-report/
frontend.old/.playwright/

# v4.0 A3 Vite frontend build output
frontend/dist/

# Playwright auth state — contains session cookies, regenerated by global-setup.js
frontend/playwright-auth.json
frontend/playwright-auth-editor.json
frontend.old/playwright-auth.json
frontend.old/playwright-auth-editor.json

# Git worktrees
.worktrees/

# Local profile configs — may contain API keys (OpenRouter, etc.).
# Tracked templates end in .example.json — copy one to <name>.json and edit locally.
backend/config/profiles/dev-default.json
backend/config/profiles/*.local.json

# R5 Phase 1 — runtime secrets (FLASK_SECRET_KEY) generated by setup scripts.
backend/.env
.env

# R5 Phase 2 — self-signed HTTPS certs (per-deployment, never committed)
backend/data/certs/

# Private / commercially sensitive docs (client assessments, internal notes).
# Kept local only — MUST NOT be pushed to public repo.
docs/private/

# v6 test-runtime artifacts — pipelines / profiles created by tests during execution.
# Production v6 dependencies (referenced by tracked pipeline JSONs) are explicitly
# committed; this pattern catches everything else.
backend/config/asr_profiles/*.json
!backend/config/asr_profiles/.gitkeep
backend/config/pipelines/903b0f4a-*.json
backend/config/pipelines/95c2bd90-*.json
backend/config/pipelines/b49ef5d4-*.json
backend/config/pipelines/ec2d55ba-*.json
backend/config/translator_profiles/
backend/config/verifier_profiles/
backend/config/refiner_profiles/120a640e-*.json
backend/config/refiner_profiles/e343a867-*.json
backend/config/llm_profiles/603811c1-*.json
backend/config/transcribe_profiles/eb5675f2-*.json

# One-shot validation snapshots / debug probes (transient evidence, not durable)
docs/superpowers/validation/*-snapshot.json
frontend/v5a*.mjs
frontend/v6_*.mjs
frontend/tests-e2e/_manual-*.mjs
frontend/tests-e2e/manual-*.spec.ts

# One-shot migration / bootstrap scripts (don't track per-run)
backend/scripts/build_v5_pipelines_zh_en.py
