# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# Virtual environment
backend/venv/
.venv/
# V6 Qwen3-ASR subprocess venv (py3.11, ~279MB; built by scripts/setup_v6.sh — LIVE, never commit)
backend/scripts/v5_prototype/venv_qwen/
# Prototype scratch outputs
backend/scripts/v5_prototype/out_nothink/

# Frontend build cache (no-build project; stray TS incremental cache)
*.tsbuildinfo

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Whisper model cache
*.pt

# Uploaded media & transcription data
backend/data/

# Temp files
*.tmp
*.log

# Claude Code
.claude/

# Skill tool state
.superpowers/

# Playwright / pytest output
test-results/

# Frontend npm artifacts (R5 Phase 1 added Playwright deps via npm)
frontend/node_modules/
frontend/playwright-report/
frontend/.playwright/

# Playwright auth state — contains session cookies, regenerated by global-setup.js.
# Broad pattern covers root, frontend/, and worktree copies.
playwright-auth*.json
frontend/tests/.v6-spec-auth.json

# Git worktrees
.worktrees/

# Local profile configs — may contain API keys (OpenRouter, etc.).
# Tracked templates end in .example.json — copy one to <name>.json and edit locally.
backend/config/profiles/dev-default.json
backend/config/profiles/*.local.json

# R5 Phase 1 — runtime secrets (FLASK_SECRET_KEY) generated by setup scripts.
backend/.env
.env

# R5 Phase 2 — self-signed HTTPS certs (per-deployment, never committed)
backend/data/certs/

# Private / commercially sensitive docs (client assessments, internal notes).
# Kept local only — MUST NOT be pushed to public repo.
docs/private/

# Token licensing — per-deployment state + owner's issuance ledger (never commit)
backend/config/license.json
scripts/licensing/issued_licenses.csv
